server {
    listen 10.0.0.10:51821 ssl;
    server_name _;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}

server {
    listen 203.0.113.10:9443 ssl;
    server_name _;

    location = /api/integrations/telegram/webhook {
        proxy_pass http://127.0.0.1:3000/api/integrations/telegram/webhook;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location / {
        return 404;
    }
}
